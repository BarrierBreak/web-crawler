{
  "name": "stateless-web-crawler-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Scalable, stateless web crawler backend built with Node.js, TypeScript, BullMQ, Redis, and Cheerio.",
  "main": "dist/server.js",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bullmq": "^5.71.0",
    "cheerio": "^1.1.2",
    "express": "^4.21.2",
    "ioredis": "^5.5.0",
    "robots-parser": "^3.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
